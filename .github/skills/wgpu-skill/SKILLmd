## Render Pipelines (offscreen)

```python
from __future__ import annotations

import numpy as np
import wgpu


# NDC triangle — positions and per-vertex colours embedded in shader.
TRIANGLE_WGSL = """
struct VertexOutput {
    @builtin(position) pos   : vec4<f32>,
    @location(0)       color : vec4<f32>,
};

@vertex
fn vs_main(@builtin(vertex_index) vi : u32) -> VertexOutput {
    var positions = array<vec2<f32>, 3>(
        vec2<f32>( 0.0,  0.8),
        vec2<f32>(-0.8, -0.8),
        vec2<f32>( 0.8, -0.8),
    );
    var colors = array<vec4<f32>, 3>(
        vec4<f32>(1.0, 0.0, 0.0, 1.0),
        vec4<f32>(0.0, 1.0, 0.0, 1.0),
        vec4<f32>(0.0, 0.0, 1.0, 1.0),
    );
    var out : VertexOutput;
    out.pos   = vec4<f32>(positions[vi], 0.0, 1.0);
    out.color = colors[vi];
    return out;
}

@fragment
fn fs_main(in : VertexOutput) -> @location(0) vec4<f32> {
    return in.color;
}
"""

TEXTURE_FORMAT = wgpu.TextureFormat.rgba8unorm


def render_triangle_offscreen(
    device: wgpu.GPUDevice,
    width: int = 256,
    height: int = 256,
) -> np.ndarray:
    """Render a coloured triangle offscreen and return it as RGBA pixels.

    Parameters:
        device: The GPU device.
        width:  Output image width in pixels.
        height: Output image height in pixels.

    Returns:
        np.ndarray: Shape ``(height, width, 4)`` uint8 RGBA array.
    """
    # --- Render target texture ---
    texture = device.create_texture(
        size=(width, height, 1),
        format=TEXTURE_FORMAT,
        usage=(
            wgpu.TextureUsage.RENDER_ATTACHMENT
            | wgpu.TextureUsage.COPY_SRC
        ),
        label="render_target",
    )
    texture_view = texture.create_view()

    # --- Shader ---
    shader = device.create_shader_module(code=TRIANGLE_WGSL)

    # --- Render pipeline (layout="auto" infers bind-group layouts) ---
    pipeline = device.create_render_pipeline(
        layout="auto",
        vertex={"module": shader, "entry_point": "vs_main"},
        fragment={
            "module": shader,
            "entry_point": "fs_main",
            "targets": [{"format": TEXTURE_FORMAT}],
        },
        primitive={"topology": wgpu.PrimitiveTopology.triangle_list},
    )

    # --- Render pass ---
    encoder = device.create_command_encoder()
    render_pass = encoder.begin_render_pass(
        color_attachments=[
            {
                "view": texture_view,
                "resolve_target": None,
                "clear_value": (0.1, 0.1, 0.1, 1.0),
                "load_op": wgpu.LoadOp.clear,
                "store_op": wgpu.StoreOp.store,
            }
        ],
    )
    render_pass.set_pipeline(pipeline)
    render_pass.draw(3)  # 3 vertices, no index buffer
    render_pass.end()
    device.queue.submit([encoder.finish()])

    # --- Read back pixels ---
    raw = device.queue.read_texture(
        {"texture": texture, "mip_level": 0, "origin": (0, 0, 0)},
        {"offset": 0, "bytes_per_row": width * 4},
        (width, height, 1),
    )
    pixels = np.frombuffer(raw, dtype=np.uint8).reshape(height, width, 4)
    return pixels.copy()
```

