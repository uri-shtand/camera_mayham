## Compute Pipelines

### Low-level approach

```python
from __future__ import annotations

import numpy as np
import wgpu


DOUBLE_WGSL = """
@group(0) @binding(0) var<storage, read>       input  : array<f32>;
@group(0) @binding(1) var<storage, read_write> output : array<f32>;

@compute @workgroup_size(64)
fn main(@builtin(global_invocation_id) gid : vec3<u32>) {
    let i = gid.x;
    if (i < arrayLength(&input)) {
        output[i] = input[i] * 2.0;
    }
}
"""


def run_double_compute(
    device: wgpu.GPUDevice,
    values: np.ndarray,
) -> np.ndarray:
    """Double every element of ``values`` on the GPU.

    Parameters:
        device: The GPU device.
        values: A 1-D float32 numpy array.

    Returns:
        np.ndarray: A new float32 array with each element doubled.
    """
    n = len(values)
    byte_size = values.nbytes

    # --- Buffers ---
    input_buf = device.create_buffer_with_data(
        data=values.tobytes(),
        usage=wgpu.BufferUsage.STORAGE,
        label="input_buffer",
    )
    output_buf = device.create_buffer(
        size=byte_size,
        usage=wgpu.BufferUsage.STORAGE | wgpu.BufferUsage.COPY_SRC,
        label="output_buffer",
    )

    # --- Shader ---
    shader = device.create_shader_module(code=DOUBLE_WGSL)

    # --- Bind group layout ---
    bgl = device.create_bind_group_layout(
        entries=[
            {
                "binding": 0,
                "visibility": wgpu.ShaderStage.COMPUTE,
                "buffer": {
                    "type": wgpu.BufferBindingType.read_only_storage
                },
            },
            {
                "binding": 1,
                "visibility": wgpu.ShaderStage.COMPUTE,
                "buffer": {"type": wgpu.BufferBindingType.storage},
            },
        ],
    )

    # --- Bind group ---
    bind_group = device.create_bind_group(
        layout=bgl,
        entries=[
            {"binding": 0, "resource": {"buffer": input_buf}},
            {"binding": 1, "resource": {"buffer": output_buf}},
        ],
    )

    # --- Pipeline ---
    pipeline_layout = device.create_pipeline_layout(
        bind_group_layouts=[bgl]
    )
    pipeline = device.create_compute_pipeline(
        layout=pipeline_layout,
        compute={"module": shader, "entry_point": "main"},
    )

    # --- Dispatch ---
    encoder = device.create_command_encoder()
    pass_ = encoder.begin_compute_pass()
    pass_.set_pipeline(pipeline)
    pass_.set_bind_group(0, bind_group)
    workgroups = (n + 63) // 64
    pass_.dispatch_workgroups(workgroups)
    pass_.end()
    device.queue.submit([encoder.finish()])

    # --- Read back ---
    raw = device.queue.read_buffer(output_buf)
    return np.frombuffer(raw, dtype=np.float32).copy()
```

### Convenience helper (`compute_with_buffers`)

For quick, one-shot compute dispatches use the utility helper:

```python
import numpy as np
from wgpu.utils.compute import compute_with_buffers


SQUARE_WGSL = """
@group(0) @binding(0) var<storage, read>       input  : array<f32>;
@group(0) @binding(1) var<storage, read_write> output : array<f32>;

@compute @workgroup_size(1)
fn main(@builtin(global_invocation_id) gid : vec3<u32>) {
    let i = gid.x;
    output[i] = input[i] * input[i];
}
"""


def square_array(values: np.ndarray) -> np.ndarray:
    """Square every element of ``values`` using a GPU compute shader.

    Uses ``compute_with_buffers`` which handles device creation,
    buffer setup, and dispatch automatically.

    Parameters:
        values: A 1-D float32 numpy array.

    Returns:
        np.ndarray: A float32 array with each element squared.
    """
    n = len(values)
    result = compute_with_buffers(
        input_arrays={0: values.astype(np.float32)},
        output_arrays={1: (n, "f")},
        shader=SQUARE_WGSL,
        n=n,
    )
    return np.array(result[1], dtype=np.float32)
```

