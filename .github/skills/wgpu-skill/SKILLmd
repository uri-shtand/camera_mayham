## Unit Testing

### Principles

- Each test must be **self-contained** and not depend on global mutable state.
- Tests that exercise GPU paths require a real or software-fallback device.
- Name test functions `test_<what_is_tested>`.
- Assert specific output values rather than just checking types.
- Use `pytest.approx` or `numpy.testing` for floating-point comparisons.
- Use a **session-scoped** `device` fixture to avoid repeated initialisation.

### Example test file

```python
"""Tests for GPU compute utilities.

These tests verify that GPU compute shaders produce correct numerical
results. A default wgpu device is created once per session to avoid
repeated initialisation overhead.
"""
from __future__ import annotations

import numpy as np
import pytest
import wgpu
from wgpu.utils import get_default_device
from wgpu.utils.compute import compute_with_buffers


# ---------------------------------------------------------------------------
# Fixtures
# ---------------------------------------------------------------------------

@pytest.fixture(scope="session")
def device() -> wgpu.GPUDevice:
    """Return a shared GPU device for the entire test session.

    Session scope avoids expensive re-initialisation for each test
    while keeping individual tests fully independent.
    """
    return get_default_device()


# ---------------------------------------------------------------------------
# Production helper under test
# ---------------------------------------------------------------------------

DOUBLE_WGSL = """
@group(0) @binding(0) var<storage, read>       input  : array<f32>;
@group(0) @binding(1) var<storage, read_write> output : array<f32>;

@compute @workgroup_size(64)
fn main(@builtin(global_invocation_id) gid : vec3<u32>) {
    let i = gid.x;
    if (i < arrayLength(&input)) {
        output[i] = input[i] * 2.0;
    }
}
"""


def gpu_double(
    device: wgpu.GPUDevice,
    values: np.ndarray,
) -> np.ndarray:
    """Return a new array with every element of ``values`` doubled."""
    n = len(values)
    result = compute_with_buffers(
        input_arrays={0: values.astype(np.float32)},
        output_arrays={1: (n, "f")},
        shader=DOUBLE_WGSL,
        n=n,
    )
    return np.array(result[1], dtype=np.float32)


# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------

class TestGpuDouble:
    """Test suite for the gpu_double compute helper."""

    def test_basic_values(self, device: wgpu.GPUDevice) -> None:
        """gpu_double should return each input element multiplied by 2."""
        values = np.array([1.0, 2.0, 3.0, 4.0], dtype=np.float32)
        result = gpu_double(device, values)
        expected = np.array([2.0, 4.0, 6.0, 8.0], dtype=np.float32)
        np.testing.assert_allclose(result, expected, rtol=1e-6)

    def test_zero_input(self, device: wgpu.GPUDevice) -> None:
        """gpu_double of all-zeros should return all-zeros."""
        values = np.zeros(16, dtype=np.float32)
        result = gpu_double(device, values)
        np.testing.assert_array_equal(
            result, np.zeros(16, dtype=np.float32)
        )

    def test_negative_values(self, device: wgpu.GPUDevice) -> None:
        """gpu_double should correctly handle negative inputs."""
        values = np.array([-1.0, -2.5, 0.5], dtype=np.float32)
        result = gpu_double(device, values)
        np.testing.assert_allclose(result, values * 2.0, rtol=1e-6)

    def test_large_array(self, device: wgpu.GPUDevice) -> None:
        """gpu_double handles arrays larger than one workgroup (64)."""
        values = np.arange(256, dtype=np.float32)
        result = gpu_double(device, values)
        np.testing.assert_allclose(result, values * 2.0, rtol=1e-6)

    def test_returns_copy(self, device: wgpu.GPUDevice) -> None:
        """The returned array must not share memory with the input."""
        values = np.array([1.0, 2.0], dtype=np.float32)
        result = gpu_double(device, values)
        result[0] = 999.0  # mutate result
        assert values[0] == pytest.approx(1.0)


class TestBufferRoundtrip:
    """Verify that data written to a GPU buffer can be read back intact."""

    def test_float32_roundtrip(self, device: wgpu.GPUDevice) -> None:
        """Write and read a float32 array — data must be identical."""
        data = np.array([3.14, 2.71, 1.41], dtype=np.float32)
        buf = device.create_buffer_with_data(
            data=data.tobytes(),
            usage=wgpu.BufferUsage.COPY_SRC | wgpu.BufferUsage.COPY_DST,
        )
        raw = device.queue.read_buffer(buf)
        result = np.frombuffer(raw, dtype=np.float32)
        np.testing.assert_allclose(result, data, rtol=1e-6)

    def test_uint8_roundtrip(self, device: wgpu.GPUDevice) -> None:
        """Write and read uint8 data — bytes must be identical."""
        data = np.array([0, 127, 255, 64], dtype=np.uint8)
        buf = device.create_buffer_with_data(
            data=data.tobytes(),
            usage=wgpu.BufferUsage.COPY_SRC | wgpu.BufferUsage.COPY_DST,
        )
        raw = device.queue.read_buffer(buf)
        result = np.frombuffer(raw, dtype=np.uint8)
        np.testing.assert_array_equal(result, data)
```

